		        // Firefox and other non IE browsers
		        if (e.preventDefault)
		        {
		            e.preventDefault();
		            e.stopPropagation();
		        }
		        // Internet Explorer
		        else if (e.keyCode)
		        {
		            e.keyCode = 0;
		            e.returnValue = false;
		            e.cancelBubble = true;
