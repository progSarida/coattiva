      data: $("#installmentForm").serialize()+"&save_type="+type,
      success: function(response){
        showMessage(response.error, response.msg);
        if(response.action == "elimina" && (response.error === "0" || response.error === 0))
        {
          location.reload();
          flagPrint = false;
        }
        else if(response.action == "aggiorna" && (response.error === "0" || response.error === 0)){
          $("#btnSave").hide();
          $("#btnSaveDel").show();
          flagPrint = true;
        }
      },
      error: function(risposta){
        showMessage(1, risposta.statusText);
      }
  });
  }

  function resetDate(el){

    var tot_rate = parseInt($("#number_sel").val());

    for(var i=2; i <= tot_rate; i++){
            var data_prec = $('#split_date_'+(i-1)).val().split("-");
            var year= parseInt(data_prec[0]);
            var month = parseInt(data_prec[1]);
            var day = parseInt(data_prec[2]);
            var data = new Date(year,(month-1),day);
        //alert(data);

            switch(el.value){
                case "1": var data_update  = new Date(data.getFullYear(),(data.getMonth()+1),data.getDate());// data.setMonth(data.getMonth()+1);
                            //alert(data_update);
                        $("#split_date_"+i).val(formatDateDB(data_update));
                    break;
                case "2": var data_update  = new Date(data.getFullYear(),(data.getMonth()+2),data.getDate());//data.setMonth(data.getMonth()+2);
                            //alert(data_update);
                        $("#split_date_"+i).val(formatDateDB(data_update));
                    break;
                case "3": var data_update  = new Date(data.getFullYear(),(data.getMonth()+6),data.getDate());//data.setMonth(data.getMonth()+6);
                            //alert(data_update);
                        $("#split_date_"+i).val(formatDateDB(data_update));
                    break;
                default: break;
            }
    }
}


  function creaRate(value,number,date,cadenza_rate){

    var total_var = value.attr("total");
    var number_var = number.val();
    var date_var = date.val();

    if(value.val() == "0"){
      //$('#installmentModalLabel').empty().append('<b>Rateizzazione pignoramenti</b> - <b style="color:red !important;">Errore! Prima selezionare un importo!</b>');
      showMessage(1,"Errore! Prima selezionare un importo!");
      return false;
    }
    if(date_var == ""){
      //$('#installmentModalLabel').empty().append('<b>Rateizzazione pignoramenti</b> - <b style="color:red !important;">Errore! Prima inserire la data della rateizzazione!</b>');
      showMessage(1,"Errore! Prima inserire la data della rateizzazione!");
      return false;
    }
    if(number_var < 2)
    {
      //$('#installmentModalLabel').empty().append('<b>Rateizzazione pignoramenti</b> - <b style="color:red !important;">Errore! Creare almeno due rate!</b>');
      showMessage(1,"Errore! Creare almeno due rate!");
      return false;
    }

    var impUnaRata = (parseFloat(total_var) / number_var).toFixed(2);
    var restUnaRata = parseFloat(total_var) - (impUnaRata * number_var).toFixed(2);

    var html = createInstallmentTable(impUnaRata,restUnaRata,date_var,number_var,total_var,cadenza_rate.val());

    total_choice = total_var;

    $(".hideInit").show();
    $('#container-rate').empty().append(html);

    $("#number_sel").val(number_var);

    //$('#installmentModalLabel').empty().append('<b>Rateizzazione pignoramenti</b> - <b style="color:green !important;">Rate create!</b>');
    showMessage(0,"Rate create!");

  }

  async function showMessage(type,msg){
    
    switch(type){
      case "0":
      case 0: $('#installmentModalLabel').empty().append('<b>Rateizzazione pignoramenti</b> - <b style="color:green !important;">'+msg+'</b>'); break;
      case "1":
      case 1: $('#installmentModalLabel').empty().append('<b>Rateizzazione pignoramenti</b> - <b style="color:red !important;">'+msg+'</b>'); break;
      case "2":
      case 2: $('#installmentModalLabel').empty().append('<b>Rateizzazione pignoramenti</b> - <b style="color:#F6BE00 !important;">'+msg+'</b>'); break;
      default: $('#installmentModalLabel').empty().append('<b>Rateizzazione pignoramenti</b> - <b>'+msg+'</b>'); break;
    }

    setTimeout(reset, 10000);

  }

  function reset(){
    $('#installmentModalLabel').empty().append('<b>Rateizzazione pignoramenti</b>');
  }

  function createInstallmentTable(importo,resto,data,number,totale,cadenza){

    var arrData = data.split("-");
    var Data = new Date(arrData[0],arrData[1]-1,arrData[2]);
    Data.setDate(Data.getDate()+10);

    var str = `<table class="table table-sm table-hover">
                  <colgroup>
                    <col style="width:10%;">
                    <col style="width:40%;">
                    <col style="width:50%;">
                  </colgroup>
                  <thead class="bg-primary">
                    <tr>
                      <th scope="col">#</th>
                      <th scope="col">Importo &euro; - Su un totale di `+totale+`</th>
                      <th scope="col">Data scadenza</th>
                    </tr>
                  </thead>
                  <tbody>`;

    var dateIta = null;
    var importo_def = 0;
    var disabled = "";
    var onblurDate = "";
    var totale_rate = 0;
    for(var i = 0; i < number; i++){
        
        importo_def = i==0?(parseFloat(importo)+parseFloat(resto)).toFixed(2):parseFloat(importo).toFixed(2);
        if(i>0) {
          disabled = "readonly";
          onblurDate = "";
        }
        else{ 
          disabled = "";
          onblurDate = "resetDate(document.getElementById('installment_type'));";
        }

        totale_rate+=parseFloat(importo_def);

        str += `<tr>
                <th scope="row" style="color:#244EE3;">`+(i+1)+`°</th>
                <td><input class="form-control form-control-sm split_import" type="text" onchange="set_total('sumTotal');" id="split_import_`+(i+1)+`" name="split_import[]" value="`+importo_def+`"/></td>
                <td><input class="form-control form-control-sm" type="date" `+disabled+` onblur="`+onblurDate+`" id="split_date_`+(i+1)+`" name="split_date[]" value="`+formatDateDB(Data)+`"/></td>
              </tr>`;

        switch(cadenza){
          case "1": Data.setMonth(Data.getMonth()+1); break;
          case "2": Data.setMonth(Data.getMonth()+2); break;
          case "3": Data.setMonth(Data.getMonth()+6); break;
          default: Data.setMonth(Data.getMonth()+1); break;
        }
        
    }

    str += `  <tr>
                <th scope="row" style="color:green;font-weight:bold;">Totale:</th>
                <td colspan="2" style="text-align:left;" id="sumTotal"><b style="color:green;">`+parseFloat(totale_rate).toFixed(2)+`</b></td>
              </tr>
            </tbody>
          </table>`; 

    return str;

  }

  function set_total(id){
    var newTotal = 0;
    $(".split_import").each(function( index ) {
      newTotal += parseFloat($( this ).val());
    });

    if(parseFloat(total_choice) != newTotal.toFixed(2)){
      flagSave = false;
      $("#"+id).empty().append("<b style='color:red;'>"+newTotal.toFixed(2)+"</b>");
    }
    else {
      flagSave = true;
      $("#"+id).empty().append("<b style='color:green;'>"+newTotal.toFixed(2)+"</b>");
    }
  }

  function formatDateDB(date) {
    var d = new Date(date),
        month = '' + (d.getMonth() + 1),
        day = '' + d.getDate(),
        year = d.getFullYear();

    if (month.length < 2) 
        month = '0' + month;
    if (day.length < 2) 
        day = '0' + day;

    return [year, month, day].join('-');
}

