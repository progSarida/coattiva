  function saveForm(type){
    
    //var data = $("#installmentForm").serializeArray(); // convert form to array
    //data.push({name: "save_type", value: type});
    //$.param(data)

    if(!flagSave)
    {
      showMessage(2, "I totali non corrispondono! Impossibile salvare!");
      return false;
    }


    $.ajax({
      url: "{{PATHS.WEB_ROOT}}/coattiva/ajax/saveInstallment.php",                                  // url pagina che farà query
      type: "POST",                                                   // create an ajax request to display.php
