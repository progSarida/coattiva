<script>
  function changeTipoImmobiliare(numero){
      $('.row_fabbricato'+numero).hide();
      $('.row_terreno'+numero).hide();
      let tipoImmobiliare = $('#Tipo_Immobiliare'+numero).val();
      $('.row_'+tipoImmobiliare+numero).show();
  }
</script>

