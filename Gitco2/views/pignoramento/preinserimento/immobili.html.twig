<script>

  

  var numeroImmobili = {{pvt_immobili|length}}-1;
  function enableSaveImmobili(){
    if($('.genRowImmobile').length>0)
      $('#immobileSubmit').prop('disabled',false);
    else
      $('#immobileSubmit').prop('disabled',true);
  }
  
  function rimuoviImmobile(numero){

    if(confirm("Vuoi eliminare la immobile?")){
      terzoPvtId = parseInt($('#ImmobilePvt_ID_'+numero).val());
      if(terzoPvtId>0){
        $.ajax({
          type: 'POST',
          url: '{{form_immobile.delete}}',
          data : {
            'ImmobilePvt_ID' : terzoPvtId,
            'Partita_ID' : {{partita.ID}},
            'c': '{{partita.CC}}',
            'a': {{partita.Anno_Riferimento}}
          },
          success: function(result){
              console.log(result);
              $('.rowImmobile'+numero).remove();
              enableSaveImmobili();
              alert("Eliminazione avvenuta con successo");
          },
          error: function(err){
              alert("Errore nella eliminazione!!");
              console.log(err);
          }
        });
      }
      else{
        $('.rowImmobile'+numero).remove();
        enableSaveImmobili();
      }
      
    }

     
   
  }

  function aggiungiImmobile(){
    lastTerzo = numeroImmobili;
    numeroImmobili++;

    $.ajax({
        method: "POST",
        url: "{{PATHS.WEB_ROOT}}/coattiva/templates/templateImmobile.php",
        data: {
            'rowKey' : numeroImmobili,
            'Partita_ID' : {{partita.ID}},
            'c': '{{partita.CC}}',
            'a': {{partita.Anno_Riferimento}}
        },
        dataType: 'json',
        success: function (response) {
            if( response.status === true ) {
              if($('.genRowImmobile').length>0)
                $('.rowImmobile'+lastTerzo+':last').after(response.data);
              else
                $('.rowImmobileStart').after(response.data);

                $( ".picker" ).datepicker(); 
              enableSaveImmobili();
            }
        }
    });
    

  }

  enableSaveImmobili();

</script>
